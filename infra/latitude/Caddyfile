# Public TLS reverse proxy for boringd. api.boringcomputers.com is canonical;
# the sslip.io host is kept as a fallback. boringd binds 127.0.0.1:8080
# (BORING_ADDR) so it is only reachable through this proxy.
#
# Preview subdomains (<id>--<port>.162-43-188-89.sslip.io) use on-demand TLS
# gated by boringd's /internal/tls-check, so certs are only minted for real
# machines. boringd reverse-proxies them to the guest's port.

{
	on_demand_tls {
		ask http://127.0.0.1:8080/internal/tls-check
	}
}

api.boringcomputers.com, 162-43-188-89.sslip.io {
	reverse_proxy 127.0.0.1:8080
}

*.162-43-188-89.sslip.io {
	tls {
		on_demand
	}
	reverse_proxy 127.0.0.1:8080
}
