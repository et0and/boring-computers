# boringd control plane for the live hero terminal (dev only).
# In dev, tunnel to the box first:
#   ssh -N -L 18080:localhost:8080 root@<box-ip> -i ~/.ssh/boring_latitude
# then run:  BORING_URL=http://localhost:18080 BORING_TOKEN=<token> npm run dev -w web
BORING_URL=http://localhost:18080
BORING_TOKEN=
